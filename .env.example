# Domain used by Caddy. Example: video.example.com
DOMAIN=your-domain.com

# Single-account login.
AUTH_USERNAME=player
AUTH_PASSWORD=295056
AUTH_COOKIE_SECURE=1

# AI summary provider. DeepSeek uses an OpenAI-compatible API.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ASR fallback for videos without subtitles.
ENABLE_ASR=1
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
HF_ENDPOINT=https://hf-mirror.com

# Task cleanup windows, in seconds.
TASK_TTL_SECONDS=3600
AI_TASK_TTL_SECONDS=7200
